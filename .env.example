# Custom health and room-code HTTP endpoint. May be a same-origin root-relative path.
VITE_GAME_HTTP_BASE_URL=http://localhost:2567

# Colyseus SDK endpoint for matchmaking and direct realtime transport.
VITE_COLYSEUS_URL=http://localhost:2567

# Server settings. Production startup requires ALLOWED_WEB_ORIGINS.
PORT=2567
ALLOWED_WEB_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEVELOPMENT_LOGGING=true
