{
  "name": "project-shellshock",
  "private": true,
  "version": "1.12.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,server -c cyan,magenta \"pnpm dev:web\" \"pnpm dev:server\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "pnpm build:web && pnpm build:server",
    "build:web": "tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "build:server": "tsc -p tsconfig.server.json --noEmit && tsup server/index.ts --format esm --platform node --out-dir dist-server --clean",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:simulation": "vitest run src/simulation",
    "test:server": "vitest run server src/network",
    "test:browser": "playwright test",
    "map:compile": "tsx scripts/compile-map.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.7",
    "@clerk/react": "^6.12.5",
    "@colyseus/core": "0.17.44",
    "@colyseus/schema": "4.0.27",
    "@colyseus/sdk": "0.17.43",
    "@colyseus/tools": "0.17.19",
    "@colyseus/ws-transport": "0.17.13",
    "@neondatabase/serverless": "^1.1.0",
    "@vitejs/plugin-react": "6.0.3",
    "colyseus": "0.17.10",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "phaser": "4.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "vite": "8.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@colyseus/testing": "0.17.11",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "concurrently": "^9.2.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
